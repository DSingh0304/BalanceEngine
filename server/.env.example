# Server
# Required: set these values before running in production
PORT=8080
NODE_ENV=development

# Database (required)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=BalanceEngine
DB_USER=postgres
DB_PASSWORD=postgres

# JWT (generate a real secret before using)
# Use a strong random value in production (do NOT commit secrets)
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# Redis (optional - set to your production Redis URL if used)
REDIS_URL=redis://localhost:6379

# Idempotency key TTL (24 hours in seconds)
IDEMPOTENCY_TTL_SECONDS=86400

